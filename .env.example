# ── MarginIQ configuration ──────────────────────────────────────────────
# Copy to .env and fill in data.

# ── Reasoning backend: Azure AI Foundry (required) ──────────────────────
# All LLM stages run on Azure AI Foundry.
AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_AI_API_KEY=your-azure-ai-foundry-key
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o
AZURE_AI_API_VERSION=2024-08-01-preview
AZURE_AI_TIMEOUT_SECONDS=45
AZURE_AI_MAX_RETRIES=2

# ── Foundry IQ: grounded policy retrieval (required) ────────────────────
# Foundry IQ knowledge bases are backed by Azure AI Search. Retrieval runs on the
# Search SERVICE endpoint with the Search key. The critic is grounded exclusively
# on the hosted knowledge base.
FOUNDRY_IQ_ENDPOINT=https://your-search-service.search.windows.net
FOUNDRY_IQ_API_KEY=your-azure-ai-search-admin-or-query-key
FOUNDRY_IQ_INDEX=marginiq-pricing-policy
FOUNDRY_IQ_API_VERSION=2025-11-01-preview

# ── Runtime ─────────────────────────────────────────────────────────────
MAX_ANALYSIS_MEMORY_GB=10
